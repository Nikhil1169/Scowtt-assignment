// Movie Memory — Postgres (Neon) + Auth.js adapter models + app models

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Auth.js (see https://authjs.dev/getting-started/adapters/prisma) ---

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model User {
  id                    String    @id @default(cuid())
  name                  String?
  email                 String?   @unique
  emailVerified         DateTime? @map("email_verified")
  image                 String?
  onboardingCompleted   Boolean   @default(false) @map("onboarding_completed")
  accounts              Account[]
  sessions              Session[]
  favoriteMovie         FavoriteMovie?
  movieFacts            MovieFact[]

  @@map("users")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// --- App ---

model FavoriteMovie {
  id        String   @id @default(cuid())
  userId    String   @unique @map("user_id")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  title     String
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  facts     MovieFact[]

  @@map("favorite_movies")
}

model MovieFact {
  id              String        @id @default(cuid())
  userId          String        @map("user_id")
  favoriteMovieId String        @map("favorite_movie_id")
  content         String
  createdAt       DateTime      @default(now()) @map("created_at")
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  favoriteMovie   FavoriteMovie @relation(fields: [favoriteMovieId], references: [id], onDelete: Cascade)

  @@index([userId, favoriteMovieId, createdAt(sort: Desc)])
  @@map("movie_facts")
}
