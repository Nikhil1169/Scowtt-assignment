# Neon Postgres
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# Auth.js — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Google OAuth (OAuth 2.0 Client IDs in Google Cloud Console)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: public URL in production (Auth.js also reads AUTH_URL)
# AUTH_URL="https://your-domain.com"

# Google AI Studio / Gemini API (https://aistudio.google.com/apikey)
GEMINI_API_KEY=""
# Optional: model id (default: gemini-2.0-flash). If you hit 429/quota on 2.0, try e.g. gemini-1.5-flash.
# GEMINI_MODEL="gemini-1.5-flash"

# Optional: movie fact cache in ms (default 60000). Use 0 to always generate a new fact (no cache).
# MOVIE_FACT_CACHE_MS="60000"
